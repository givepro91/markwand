{
  "name": "markwand",
  "version": "0.3.0-beta.7",
  "description": "An AI-output curator for your desktop — discover, read, and re-enter the markdown docs scattered across your AI-driven projects.",
  "main": "./out/main/index.js",
  "author": "jay@spacewalk.tech",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint src --ext .ts,.tsx",
    "dist:mac": "pnpm build && electron-builder --mac --publish never",
    "test": "vitest run",
    "bench:transport": "npx --yes tsx scripts/bench-transport.ts",
    "test:integration-ssh": "npx --yes tsx scripts/test-integration-ssh.ts",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "electron-store": "^10.0.0",
    "execa": "^9.0.0",
    "fast-glob": "^3.3.0",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "i18next": "^26.0.6",
    "mermaid": "^11.0.0",
    "picomatch": "^2.3.2",
    "react": "^19.0.0",
    "react-arborist": "^3.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.4",
    "react-markdown": "^10.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-sanitize": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.0",
    "ssh-config": "^5.1.0",
    "ssh2": "^1.17.0",
    "which": "^4.0.0",
    "zod": "^3.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "tech.spacewalk.markwand",
    "productName": "Markwand",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/ssh2/**/*.node",
      "**/node_modules/cpu-features/**/*.node"
    ],
    "buildDependenciesFromSource": false,
    "npmRebuild": false,
    "afterPack": "build/afterPack.js",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.icns",
      "identity": null,
      "hardenedRuntime": false
    },
    "dmg": {
      "sign": false,
      "window": {
        "width": 560,
        "height": 400
      },
      "contents": [
        {
          "x": 140,
          "y": 180,
          "type": "file"
        },
        {
          "x": 420,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 280,
          "y": 330,
          "type": "file",
          "path": "build/여기를 먼저 더블클릭.html"
        }
      ]
    }
  },
  "packageManager": "pnpm@10.30.1+sha512.3590e550d5384caa39bd5c7c739f72270234b2f6059e13018f975c313b1eb9fefcc09714048765d4d9efe961382c312e624572c0420762bdc5d5940cdf9be73a",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
